@model ProjetoLogin.Models.Cliente

@{
    ViewData["Title"] = "Login";
}

<main role="main">
<br />
    <section class="container">
        <aside class="col-sm-4">
            <h1 class="subtitle-doc">
                Login
            </h1>
            <div id="code_login_1">
                <div class="card">
                    <article class="card-body">
                        @if (ViewData["MSG_E"] != null)
                        {
                            <p class="alert alert-danger">@Html.Raw(ViewData["MSG_E"])</p>
                        }
                        <a asp-action="Cadastro"
                           asp-controller="Cliente"
                           class="float-right btn btn-outline-primary">
                            Cadastre-se
                        </a>
                        <h4 class="card-title mb-4 mt-1">Entrar</h4>
                        <form method="post">
                            <div class="form-group">
                                <label>E-mail</label>
                                <input asp-for="Email" class="form-control" placeholder="Email" type="email">
                            </div>
                            <div class="form-group">
                                <label>Senha</label>
                                <input asp-for="Senha" class="form-control" placeholder="******" type="password">
                                <a class="float-right" href="#">Esqueceu a senha?</a>
                            </div>
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-block"> Acessar </button>
                            </div>
                        </form>
                    </article>
                </div>
            </div>
        </aside>
    </section>
</main>

<style>
    main {
        margin-top: 20px;
        display: flex;
        justify-content: center; 
        align-items: center; 
    }

    .container {
        display: flex;
        justify-content: center;
    }

    .col-sm-4 {
        height: 400px;
        width: 500px;
    }

    .float-right btn{
        justify-content: center;
    }

    .subtitle-doc {
        text-align: center;
    }
</style>